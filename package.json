{
  "name": "stangelispass-agents",
  "version": "1.0.0",
  "description": "Agentic AI workflow system for Stängelispass",
  "type": "module",
  "private": true,
  "scripts": {
    "agent": "tsx agents/scripts/agent-runner.ts",
    "agent:pre-commit": "tsx agents/scripts/agent-runner.ts pre_commit",
    "agent:daily": "tsx agents/scripts/agent-runner.ts daily_cron",
    "agent:pr": "tsx agents/scripts/agent-runner.ts pr_opened",
    "agent:manual": "tsx agents/scripts/agent-runner.ts manual",
    "agent:dry-run": "tsx agents/scripts/agent-runner.ts manual --dry-run",
    "quality": "tsx maintain-quality.mjs",
    "quality:fix": "tsx agents/scripts/agent-runner.ts pre_commit",
    "quality:report": "tsx agents/scripts/agent-runner.ts daily_cron",
    "swarm:analyze": "node agents/scripts/run-swarm-analysis.mjs",
    "swarm:roadmap": "node agents/scripts/run-swarm-analysis.mjs roadmap_update",
    "swarm:docs": "node agents/scripts/run-swarm-analysis.mjs documentation_sync",
    "swarm:brainstorm": "node agents/scripts/run-swarm-analysis.mjs feature_brainstorm",
    "swarm:dry-run": "node agents/scripts/run-swarm-analysis.mjs"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "ajv": "^8.12.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1"
  }
}
