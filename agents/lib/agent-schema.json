{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentManifest",
  "description": "Configuration schema for agentic AI workflows",
  "type": "object",
  "required": ["name", "version", "description", "autonomy", "triggers", "actions", "permissions"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the agent",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 3,
      "maxLength": 50
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the agent",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of agent purpose",
      "minLength": 10,
      "maxLength": 500
    },
    "autonomy": {
      "type": "string",
      "enum": ["autonomous", "advisory", "hybrid"],
      "description": "Level of autonomy for the agent"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether the agent is currently enabled",
      "default": true
    },
    "triggers": {
      "type": "array",
      "description": "Events that trigger agent execution",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event", "actions"],
        "properties": {
          "event": {
            "type": "string",
            "enum": [
              "pre_commit",
              "post_commit",
              "pr_opened",
              "pr_updated",
              "daily_cron",
              "weekly_cron",
              "manual",
              "file_changed",
              "deployment",
              "test_failed"
            ]
          },
          "schedule": {
            "type": "string",
            "description": "Cron expression for scheduled triggers",
            "pattern": "^(@(annually|yearly|monthly|weekly|daily|hourly|reboot))|(@every (\\d+(ns|us|µs|ms|s|m|h))+)|((((\\d+,)+\\d+|(\\d+([/\\-])\\d+)|\\d+|\\*) ?){5,7})$"
          },
          "actions": {
            "type": "array",
            "description": "Action names to execute",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "conditions": {
            "type": "object",
            "description": "Conditional execution criteria"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "description": "Available actions the agent can perform",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["autonomous", "advisory"]
            },
            "command": {
              "type": "string",
              "description": "Shell command to execute"
            },
            "script": {
              "type": "string",
              "description": "Path to TypeScript/JavaScript script"
            },
            "approval_required": {
              "type": "boolean",
              "description": "Whether human approval is required",
              "default": false
            },
            "rollback_on_failure": {
              "type": "boolean",
              "description": "Whether to rollback changes on failure",
              "default": true
            },
            "timeout_seconds": {
              "type": "number",
              "description": "Maximum execution time in seconds",
              "minimum": 1,
              "maximum": 3600,
              "default": 300
            },
            "retry_count": {
              "type": "number",
              "description": "Number of retry attempts on failure",
              "minimum": 0,
              "maximum": 5,
              "default": 0
            },
            "conditions": {
              "type": "object",
              "description": "Conditional execution criteria"
            }
          },
          "oneOf": [
            { "required": ["command"] },
            { "required": ["script"] }
          ]
        }
      }
    },
    "permissions": {
      "type": "array",
      "description": "Permissions required by the agent",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "read:code",
          "write:code",
          "read:config",
          "write:config",
          "commit:auto_fix",
          "create:pr",
          "create:pr_comment",
          "create:issue",
          "run:tests",
          "deploy:staging",
          "deploy:production"
        ]
      }
    },
    "monitoring": {
      "type": "object",
      "description": "Monitoring and alerting configuration",
      "properties": {
        "log_level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "metrics": {
          "type": "array",
          "description": "Metrics to track",
          "items": {
            "type": "string"
          }
        },
        "alerts": {
          "type": "object",
          "properties": {
            "on_failure": {
              "type": "boolean",
              "default": true
            },
            "on_success": {
              "type": "boolean",
              "default": false
            },
            "channels": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["slack", "discord", "email", "console"]
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "author": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
